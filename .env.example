# Optional. If unset, the first visit opens /setup to create an admin password.
JEFF_ADMIN_PASSWORD=

# Optional. Use an absolute path on cloud servers if you do not want data under the app folder.
JEFF_ORDER_DB_PATH=

# Optional. Defaults to the backups folder next to orders.db.
JEFF_BACKUP_DIR=
JEFF_BACKUP_RETENTION_DAYS=30

# Optional. Set these when the app is served through HTTPS.
NEXT_PUBLIC_SITE_URL=
JEFF_COOKIE_SECURE=false

# Optional. Defaults to MelodyJayai/jeff-order-tool GitHub Releases.
JEFF_UPDATE_REPOSITORY=MelodyJayai/jeff-order-tool

# Optional. Use this instead of GitHub Releases if you publish a static JSON update manifest.
JEFF_UPDATE_MANIFEST_URL=
