# Copy this file to .env.cloud on the cloud server and edit the values.

# Required before opening the service to the Internet.
JEFF_ADMIN_PASSWORD=replace-with-a-strong-password

# The address Jeff will open from phones and other computers.
# Examples:
# JEFF_PUBLIC_URL=https://orders.example.com
# JEFF_PUBLIC_URL=http://100.x.y.z:3000
JEFF_PUBLIC_URL=
NEXT_PUBLIC_SITE_URL=

# Use true when the public URL starts with https://.
JEFF_COOKIE_SECURE=false

# Cloud mode hides the Windows installer update card in the web UI.
JEFF_DEPLOYMENT_MODE=cloud
JEFF_DISABLE_IN_APP_UPDATES=true
JEFF_ENABLE_RETURN_WORKFLOW=false

# Recommended while the office PC remains the only place that edits orders.
# Change to false only after the final cutover makes the cloud the primary data source.
JEFF_CLOUD_SYNC_READ_ONLY=true

# Windows scripts use D:\JeffOrderToolCloud\data by default.
# Docker uses /app/data/orders.db and /app/data/backups.
JEFF_ORDER_DB_PATH=
JEFF_BACKUP_DIR=
JEFF_BACKUP_RETENTION_DAYS=30

# Optional. Change if another service already uses 3000.
PORT=3000
